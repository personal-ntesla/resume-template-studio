          "text": "：",
          "xMin": 554.292,
          "yMin": 372.041,
          "xMax": 565.292,
          "yMax": 387.441
        },
        {
          "text": "Photoshop、CorelDRAW、Illustrator、Pagemaker",
          "xMin": 240.85,
