          "yMax": 522.111
        },
        {
          "text": "年",
          "xMin": 128.2,
          "yMin": 508.111,
          "xMax": 142.2,
          "yMax": 522.111
        },
        {
          "text": "全市即席挥毫书法大赛二等奖",
          "xMin": 188.05,
          "yMin": 509.261,
          "xMax": 370.05,
          "yMax": 523.261
        },
        {
          "text": "英语朗读比赛第三名",
          "xMin": 188.05,
          "yMin": 539.261,
          "xMax": 314.05,
          "yMax": 553.261
        },
        {
          "text": "被评为全市“优秀教师”",
          "xMin": 188.05,
          "yMin": 569.261,
          "xMax": 325.178,
          "yMax": 583.261
        }
      ]
    },
